{
  "name": "hordr",
  "description": "Manage a horde of coding agents through beans, worktrees, and workflows",
  "version": "0.1.0",
  "author": "Fabian Schuh",
  "bin": {
    "hordr": "./bin/run.js"
  },
  "bugs": "https://github.com/herdr/hordr/issues",
  "dependencies": {
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "yaml": "^2",
    "zod": "^3"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/mocha": "^10",
    "@types/node": "^18",
    "chai": "^4",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "mocha": "^11",
    "oclif": "^4",
    "shx": "^0.3.3",
    "ts-node": "^10",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/herdr/hordr",
  "keywords": [
    "oclif",
    "herdr",
    "beans",
    "agents"
  ],
  "license": "MIT",
  "type": "module",
  "oclif": {
    "bin": "hordr",
    "dirname": "hordr",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help"
    ],
    "topicSeparator": " ",
    "topics": {}
  },
  "repository": "herdr/hordr",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "bun run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md"
  }
}
